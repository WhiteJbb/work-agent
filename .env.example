# ===== LLM =====
# 사용할 provider: "openai_compatible" 또는 "ollama". 비워두면 LLM 미설정 상태(초안 생성 시 안내).
LLM_PROVIDER=

# --- openai_compatible provider (vLLM / OpenAI / Ollama의 /v1 엔드포인트 공통) ---
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ollama 네이티브 provider ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# LLM 컨텍스트 예산(문자 수). 수집한 source를 이 한도로 잘라 프롬프트에 넣는다.
CONTEXT_CHAR_BUDGET=12000

# ===== Notion =====
# 비워두면 mock(JSON 백엔드)으로 동작. 실제 연동 시 integration token + DB id를 채운다.
NOTION_API_KEY=
NOTION_BLOG_DATABASE_ID=
NOTION_IDEA_DATABASE_ID=
NOTION_WORKLOG_DATABASE_ID=
# 초안 소스로 본문을 읽어올 Notion 페이지 id(쉼표 구분). "정리해 둔 문서"를 직접 가리킬 때.
NOTION_SOURCE_PAGE_IDS=

# ===== Paths (보통 수정 불필요) =====
WORKSPACE_DIR=workspace

# ===== Git source =====
# suggest-topics / write-draft가 참고할 최근 커밋 수
GIT_LOG_LIMIT=20
# 초안 근거로 커밋 diff 일부를 포함할지, 커밋당 diff 최대 문자 수
GIT_INCLUDE_DIFF=true
GIT_DIFF_MAX_CHARS=800

# ===== Messenger (선택) =====
# 비우면 봇 비활성. 양방향 봇을 쓰려면 telegram으로 설정.
MESSENGER_PROVIDER=
TELEGRAM_BOT_TOKEN=
# 봇에 명령할 수 있는 chat id(쉼표 구분). 본인 id로 제한 권장.
TELEGRAM_ALLOWED_CHAT_IDS=
# 알림(outbound)을 보낼 기본 chat id.
TELEGRAM_CHAT_ID=
