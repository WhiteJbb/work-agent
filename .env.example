# ===== LLM =====
# 최종 폴백 provider. "openai_compatible", "ollama", "gemini" 중 하나.
LLM_PROVIDER=gemini

# 분류·라우팅·짧은 요약용 provider (로컬 LLM 미사용 시 gemini lite로 폴백)
LOCAL_LLM_PROVIDER=ollama
# 글쓰기·초안·정제용 provider
WRITER_PROVIDER=gemini
# 긴 컨텍스트 글쓰기용 provider (weekly-distill, summarize-project 등)
LONG_WRITER_PROVIDER=kimi
# 최종 다듬기용 provider (revise-blog, resume 최종 등)
POLISH_PROVIDER=openai_compatible

# --- OpenAI / OpenAI-compatible provider ---
# fallback chain에 포함하려면 OPENAI_API_KEY를 설정한다.
# 실제 OpenAI API: OPENAI_BASE_URL=https://api.openai.com/v1
# 로컬 vLLM 서버: OPENAI_BASE_URL=http://localhost:8000/v1 (API 키 불필요 시 OPENAI_API_KEY= 로 비워두면 chain 제외)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 모델이 생성할 최대 토큰 수. vLLM 등 context window가 작은 모델에서 줄여야 함.
OPENAI_MAX_TOKENS=1024
# 모델의 context window 크기(토큰). 설정 시 프롬프트를 자동 truncation.
# 예) vLLM --max-model-len 8192 로 띄웠다면 8192로 설정. 0=제한 없음.
OPENAI_CONTEXT_WINDOW=0

# --- ollama 네이티브 provider ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# --- Gemini provider ---
GEMINI_API_KEY=
GEMINI_LITE_MODEL=gemini-2.5-flash-lite   # light task (분류/요약) 1순위
GEMINI_FLASH_MODEL=gemini-2.5-flash       # writer task 1순위

# --- Kimi (Moonshot AI) provider (long_writer 1순위) ---
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2

# LLM 컨텍스트 예산(문자 수). 수집한 source를 이 한도로 잘라 프롬프트에 넣는다.
# Gemini: 12000~30000 / vLLM 8k 모델: 14000 이하 권장
CONTEXT_CHAR_BUDGET=12000
# LLM HTTP 시도 횟수(1=재시도 없음). 일시적 오류/5xx에 지수 백오프 재시도.
LLM_MAX_RETRIES=2
# LLM HTTP 타임아웃(초)
LLM_TIMEOUT=300

# ===== Obsidian =====
OBSIDIAN_VAULT_PATH=
WIKI_FOLDER=60_Wiki

# ===== Git source =====
GIT_LOG_LIMIT=20
GIT_INCLUDE_DIFF=true
GIT_DIFF_MAX_CHARS=800

# ===== Messenger (선택) =====
# 비우면 봇 비활성. 양방향 봇을 쓰려면 telegram으로 설정.
MESSENGER_PROVIDER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CHAT_ID=
