# ===== LLM =====
# 최종 폴백 provider. "openai_compatible", "ollama", "gemini" 중 하나.
LLM_PROVIDER=gemini

# 분류·라우팅·짧은 요약용 provider (로컬 LLM 미사용 시 gemini lite로 폴백)
LOCAL_LLM_PROVIDER=ollama
# 글쓰기·초안·정제용 provider
WRITER_PROVIDER=gemini

# --- openai_compatible provider (vLLM / OpenAI / Ollama의 /v1 엔드포인트 공통) ---
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ollama 네이티브 provider ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# --- Gemini provider ---
GEMINI_API_KEY=
GEMINI_LITE_MODEL=gemini-2.5-flash-lite   # 로컬 LLM 폴백 시 사용
GEMINI_FLASH_MODEL=gemini-2.5-flash       # 글쓰기용

# LLM 컨텍스트 예산(문자 수). 수집한 source를 이 한도로 잘라 프롬프트에 넣는다.
CONTEXT_CHAR_BUDGET=12000
# LLM HTTP 시도 횟수(1=재시도 없음). 일시적 오류/5xx에 지수 백오프 재시도.
LLM_MAX_RETRIES=2
# LLM HTTP 타임아웃(초)
LLM_TIMEOUT=300

# ===== Notion (legacy, 기본 비활성) =====
# Vault 기반 파이프라인으로 대체됨. 활성화하려면 LEGACY_NOTION_ENABLED=true로 변경.
LEGACY_NOTION_ENABLED=false
NOTION_API_KEY=
NOTION_BLOG_DATABASE_ID=
NOTION_IDEA_DATABASE_ID=
NOTION_WORKLOG_DATABASE_ID=
NOTION_SOURCE_PAGE_IDS=

# ===== Obsidian =====
OBSIDIAN_VAULT_PATH=
# 읽을 노트를 태그로 필터링(쉼표 구분). 비우면 전체 노트.
OBSIDIAN_TAGS=
# 읽을 노트를 폴더로 필터링(쉼표 구분, 볼트 기준 상대경로). 비우면 볼트 전체.
OBSIDIAN_FOLDERS=
WIKI_FOLDER=60_Wiki

# ===== Paths =====
# Notion mock 파일 위치에만 사용됨 (보통 수정 불필요)
WORKSPACE_DIR=workspace

# ===== Git source =====
GIT_LOG_LIMIT=20
GIT_INCLUDE_DIFF=true
GIT_DIFF_MAX_CHARS=800

# ===== Messenger (선택) =====
# 비우면 봇 비활성. 양방향 봇을 쓰려면 telegram으로 설정.
MESSENGER_PROVIDER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CHAT_ID=
