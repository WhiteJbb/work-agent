# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Env / secrets
.env
.env.*
!.env.example

# Notion mock store
workspace/.notion_mock.json

# Generated drafts (샘플 docs는 추적, 생성 초안은 제외)
workspace/drafts/*
!workspace/drafts/.gitkeep
workspace/blogs/*
!workspace/blogs/.gitkeep
workspace/worklogs/*
!workspace/worklogs/.gitkeep

# OS / IDE
.DS_Store
.idea/
.vscode/
*.log

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
